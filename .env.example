# circula — variables de entorno
# Copiar a .env y ajustar: cp .env.example .env
#
# Si ya tenías .env y cambias POSTGRES_PASSWORD, puede fallar la conexión
# (el volumen db guarda la contraseña inicial). Solución: docker compose down -v

# Docker (obligatorias para compose.yml sin override; override usa imágenes fijas)
DOCKER_IMAGE_BACKEND=circula-backend
DOCKER_IMAGE_FRONTEND=circula-frontend
TAG=latest
STACK_NAME=circula
DOMAIN=localhost

# PostgreSQL
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis
POSTGRES_DB=app

# Backend — requeridas por app (SECRET_KEY >= 32 chars en producción)
PROJECT_NAME=circula
SECRET_KEY=dev-secret-key-change-in-production-32chars-min
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Backend — URLs y CORS (dev local)
FRONTEND_HOST=http://localhost:4200
ENVIRONMENT=local
BACKEND_CORS_ORIGINS=http://localhost:4200,http://localhost:80,http://127.0.0.1:4200

# SMTP (dev: mailcatcher en compose.override)
SMTP_HOST=mailcatcher
SMTP_PORT=1025
SMTP_TLS=false
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@example.com

# Opcional
SENTRY_DSN=

# Google Calendar — Domain-Wide Delegation
# JSON completo de la service account en una sola línea. NUNCA subir el real.
GOOGLE_SERVICE_ACCOUNT_JSON=

# MinIO (servidor de imágenes S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changethis
MINIO_BUCKET=circula
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
# STORAGE_BACKEND: "minio" (prod/docker) o "local" (fallback sin contenedor)
STORAGE_BACKEND=minio